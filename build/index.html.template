<!DOCTYPE html>
<html>
<head>
    <title>Container Info</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background: #1a1a2e;
            color: #eee;
        }
        .card {
            background: #16213e;
            border-radius: 12px;
            padding: 40px 60px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
            text-align: center;
        }
        h1 { color: #e94560; margin-bottom: 30px; }
        .info { font-size: 1.3em; margin: 15px 0; }
        .label { color: #999; }
        .value { color: #0f3460; background: #e94560; padding: 4px 16px; border-radius: 6px; font-weight: bold; color: #fff; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Container Info</h1>
        <div class="info">
            <span class="label">Hostname:</span>
            <span class="value">HOSTNAME_PLACEHOLDER</span>
        </div>
        <div class="info">
            <span class="label">IP Address:</span>
            <span class="value">IP_PLACEHOLDER</span>
        </div>
    </div>
</body>
</html>
